# ---- Core ----
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000

# ---- Data stores ----
# Use the non-superuser `app` role so RLS is enforced (see src/db/rls.sql).
DATABASE_URL=postgres://app:app@localhost:5432/sahaj
# A superuser/owner URL used ONLY for migrations + applying RLS (DDL).
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/sahaj
# On managed hosts with ONE connection string (Render/Neon/Supabase): leave DATABASE_URL
# as the owner and set DB_APP_ROLE=app so each tenant transaction runs `SET LOCAL ROLE app`
# and RLS still applies. Leave empty for the local two-role setup above.
DB_APP_ROLE=
REDIS_URL=redis://localhost:6379

# ---- LLM (leave GEMINI_API_KEY empty to use the built-in mock provider) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ---- Meta WhatsApp Cloud API ----
# From your Meta app. VERIFY_TOKEN is any string you choose; set the same in the webhook config.
META_VERIFY_TOKEN=sahaj-verify-token
META_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---- Telegram (owner approvals + escalations) ----
TELEGRAM_BOT_TOKEN=

# ---- Secrets ----
# 32-byte base64 key for encrypting per-tenant channel credentials at rest.
ENCRYPTION_KEY=

# ---- Dashboard API auth ----
# Production: dashboard requests need a Supabase-issued JWT (HS256) in Authorization: Bearer
# plus an X-Sahaj-Tenant-Id header. Set this to your Supabase project's JWT secret.
SUPABASE_JWT_SECRET=
# Local/dev only convenience: with NODE_ENV != production, requests carrying this tenant id
# (as X-Sahaj-Tenant-Id, no bearer token) are treated as an authenticated owner. Disabled
# entirely in production regardless of this value.
DASHBOARD_DEV_TENANT_ID=
DASHBOARD_DEV_USER_ID=
# Comma-separated allowed origins for the dashboard frontend (CORS).
DASHBOARD_CORS_ORIGIN=http://localhost:3001

# ---- Auto-send / graduation tuning ----
AUTOSEND_CONFIDENCE_THRESHOLD=0.75
GRADUATION_MIN_SAMPLES=20
GRADUATION_MIN_CLEAN_RATE=0.95
